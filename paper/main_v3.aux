\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Japan within-country binary AUC, five-fold cross-validated mean ($\pm $ SD) by model and specification. ``Full'' is $J_1$ (distance, footprint, MMI, GSI overlays); ``$F_0$'' is distance-only. Logistic regression is not run on $F_0$ because the univariate logit case is degenerate.\relax }}{19}{table.caption.31}\protected@file@percent }
\newlabel{tab:japan-within}{{9}{19}{Japan within-country binary AUC, five-fold cross-validated mean ($\pm $ SD) by model and specification. ``Full'' is $J_1$ (distance, footprint, MMI, GSI overlays); ``$F_0$'' is distance-only. Logistic regression is not run on $F_0$ because the univariate logit case is degenerate.\relax }{table.caption.31}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Three-country distance-only ($F_0$) Random Forest, binary AUC. (a) Within-country baselines for Nepal, T\"urkiye and Japan. (b) Pooled three-country fits with and without a categorical country indicator. Bars are five-fold cross-validated means with $\pm 1$ SD whiskers; the dashed line is the no-skill threshold. The pooled three-country fit improves over the strongest within-country baseline (Nepal at $0.77$) by approximately $0.02$, and adding the country indicator is essentially neutral.\relax }}{19}{figure.caption.33}\protected@file@percent }
\newlabel{fig:f0-pooled-vs-within}{{6}{19}{Three-country distance-only ($F_0$) Random Forest, binary AUC. (a) Within-country baselines for Nepal, T\"urkiye and Japan. (b) Pooled three-country fits with and without a categorical country indicator. Bars are five-fold cross-validated means with $\pm 1$ SD whiskers; the dashed line is the no-skill threshold. The pooled three-country fit improves over the strongest within-country baseline (Nepal at $0.77$) by approximately $0.02$, and adding the country indicator is essentially neutral.\relax }{figure.caption.33}{}}
\@writefile{toc}{\contentsline {paragraph}{$3\times 3$ transfer on $F_0$.}{19}{section*.35}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Within-country and pooled three-country $F_0$ Random Forest results. Five-fold cross-validated binary AUC, mean $\pm $ SD. The pooled fits use \texttt  {rsample::vfold\_cv} stratified by \texttt  {country}, so each fold contains all three countries.\relax }}{20}{table.caption.34}\protected@file@percent }
\newlabel{tab:f0-pooled}{{10}{20}{Within-country and pooled three-country $F_0$ Random Forest results. Five-fold cross-validated binary AUC, mean $\pm $ SD. The pooled fits use \texttt {rsample::vfold\_cv} stratified by \texttt {country}, so each fold contains all three countries.\relax }{table.caption.34}{}}
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Three-country $F_0$ train-to-test transfer matrix, Random Forest, binary AUC. Diagonal cells come from the single 80/20 train-test split used inside the transfer experiment, not from five-fold CV; they should be read as comparison anchors for the off-diagonal cells, not as best within-country estimates. The corresponding five-fold CV within-country baselines are reported in Table\nobreakspace  {}\ref  {tab:f0-pooled}. Bold cells are below the $0.5$ no-skill line.\relax }}{20}{table.caption.36}\protected@file@percent }
\newlabel{tab:f0-transfer-matrix}{{11}{20}{Three-country $F_0$ train-to-test transfer matrix, Random Forest, binary AUC. Diagonal cells come from the single 80/20 train-test split used inside the transfer experiment, not from five-fold CV; they should be read as comparison anchors for the off-diagonal cells, not as best within-country estimates. The corresponding five-fold CV within-country baselines are reported in Table~\ref {tab:f0-pooled}. Bold cells are below the $0.5$ no-skill line.\relax }{table.caption.36}{}}
\@writefile{toc}{\contentsline {paragraph}{Why distance fails: the marginal distance--damage curves.}{20}{section*.37}\protected@file@percent }
\citation{ghimire2024host}
\citation{patten2024datadriven}
\citation{ghimire2024host}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Country-specific marginal distance--damage curves on $F_0$. Each line is the empirical severe-damage rate within country-specific quantile bins of asset-level distance to source; point size scales with bin count. Distance is plotted on a log scale because the three countries cover very different distance ranges ($\sim $1--80\nobreakspace  {}km for Japan, district-aggregated up to $\sim $300\nobreakspace  {}km for Nepal). Diverging shapes between Japan and the two survey-based inventories explain why the off-diagonal Japan cells of the $F_0$ transfer matrix sit below the $0.5$ no-skill line.\relax }}{21}{figure.caption.38}\protected@file@percent }
\newlabel{fig:distance-damage-curve}{{7}{21}{Country-specific marginal distance--damage curves on $F_0$. Each line is the empirical severe-damage rate within country-specific quantile bins of asset-level distance to source; point size scales with bin count. Distance is plotted on a log scale because the three countries cover very different distance ranges ($\sim $1--80~km for Japan, district-aggregated up to $\sim $300~km for Nepal). Diverging shapes between Japan and the two survey-based inventories explain why the off-diagonal Japan cells of the $F_0$ transfer matrix sit below the $0.5$ no-skill line.\relax }{figure.caption.38}{}}

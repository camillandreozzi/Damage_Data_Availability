\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Simulation results, binary AUC averaged over models, repetitions and label-noise scenarios. AUC degrades systematically as the share of shared predictors (\texttt  {p\_shared}) shrinks and as country-specific measurement error (\texttt  {sigma\_measure}) grows.\relax }}{22}{figure.caption.39}\protected@file@percent }
\newlabel{fig:sim-surface}{{8}{22}{Simulation results, binary AUC averaged over models, repetitions and label-noise scenarios. AUC degrades systematically as the share of shared predictors (\texttt {p\_shared}) shrinks and as country-specific measurement error (\texttt {sigma\_measure}) grows.\relax }{figure.caption.39}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Variance decomposition from the simulation. For AUC and macro-F1 the compatibility regime explains roughly $0.52$ and $0.56$ of the variance respectively, against $0.02$ and $0.003$ for model family; for accuracy the picture inverts.\relax }}{22}{figure.caption.40}\protected@file@percent }
\newlabel{fig:sim-variance}{{9}{22}{Variance decomposition from the simulation. For AUC and macro-F1 the compatibility regime explains roughly $0.52$ and $0.56$ of the variance respectively, against $0.02$ and $0.003$ for model family; for accuracy the picture inverts.\relax }{figure.caption.40}{}}
